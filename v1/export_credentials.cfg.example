; export_credentials.cfg — TEMPLATE (non committato)
;
; Godot 4.6 usa questo file per tenere password/keystore path FUORI
; dal tracked export_presets.cfg. Il nome `export_credentials.cfg` e`
; in .gitignore — MAI committare il file reale.
;
; Setup locale (Renan / dev machine):
;   1. cp v1/export_credentials.cfg.example v1/export_credentials.cfg
;   2. Edita con il path reale del keystore + password
;   3. Verifica `git status` → export_credentials.cfg NON compare
;
; In CI: questo file non esiste. Il workflow build.yml genera il keystore
; da GitHub Secrets e patcha export_presets.cfg a runtime.
;
; Referenze:
;   docs/ANDROID_SIGNING.md
;   scripts/generate_keystores.sh
;   BUILD_RELEASE_PLAN.md §3

[keystore/release]
keystore/release="/home/USER/.relax-room-keys/release.keystore"
keystore/release_user="YOUR_ALIAS"
keystore/release_password="YOUR_STORE_PASSWORD"

[keystore/debug]
keystore/debug="/home/USER/.relax-room-keys/debug.keystore"
keystore/debug_user="androiddebugkey"
keystore/debug_password="android"
