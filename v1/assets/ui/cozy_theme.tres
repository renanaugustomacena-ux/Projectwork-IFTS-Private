; ============================================================================
; THEME RESOURCE — Global application
; ============================================================================
[resource]

; --- Colors (warm cozy palette) ---
default_font_color = Color(0.95, 0.9, 0.8, 1)

; --- Button ---
Button/colors/font_color = Color(0.95, 0.9, 0.8, 1)
Button/colors/font_hover_color = Color(1, 0.98, 0.9, 1)
Button/colors/font_pressed_color = Color(0.8, 0.75, 0.65, 1)
Button/colors/font_disabled_color = Color(0.5, 0.48, 0.45, 0.7)
Button/colors/font_focus_color = Color(1, 0.98, 0.9, 1)
Button/font_sizes/font_size = 16
Button/styles/normal = SubResource("btn_normal")
Button/styles/hover = SubResource("btn_hover")
Button/styles/pressed = SubResource("btn_pressed")
Button/styles/disabled = SubResource("btn_disabled")
Button/styles/focus = SubResource("btn_focus")

; --- Label ---
Label/colors/font_color = Color(0.95, 0.9, 0.8, 1)
Label/colors/font_shadow_color = Color(0.1, 0.08, 0.06, 0.3)
Label/constants/shadow_offset_x = 1
Label/constants/shadow_offset_y = 1

; --- PanelContainer ---
PanelContainer/styles/panel = SubResource("panel_bg")

; --- ScrollContainer ---
ScrollContainer/styles/panel = SubResource("scroll_bg")

; --- HSlider ---
HSlider/styles/slider = SubResource("slider_bg")
HSlider/styles/grabber_area = SubResource("slider_grabber")
HSlider/styles/grabber_area_highlight = SubResource("slider_grabber")

; --- LineEdit ---
LineEdit/colors/font_color = Color(0.95, 0.9, 0.8, 1)
LineEdit/colors/font_placeholder_color = Color(0.7, 0.65, 0.55, 0.5)
LineEdit/colors/caret_color = Color(0.95, 0.85, 0.7, 1)
LineEdit/colors/selection_color = Color(0.6, 0.45, 0.3, 0.4)
LineEdit/styles/normal = SubResource("lineedit_normal")
LineEdit/styles/focus = SubResource("lineedit_focus")

; --- OptionButton (language dropdown, etc.) ---
OptionButton/colors/font_color = Color(0.95, 0.9, 0.8, 1)
OptionButton/colors/font_hover_color = Color(1, 0.98, 0.9, 1)
OptionButton/styles/normal = SubResource("option_normal")
OptionButton/styles/hover = SubResource("btn_hover")
OptionButton/styles/pressed = SubResource("btn_pressed")
OptionButton/styles/focus = SubResource("btn_focus")

; --- PopupMenu (dropdown list) ---
PopupMenu/colors/font_color = Color(0.95, 0.9, 0.8, 1)
PopupMenu/colors/font_hover_color = Color(1, 0.98, 0.9, 1)
PopupMenu/styles/panel = SubResource("popup_bg")
PopupMenu/styles/hover = SubResource("popup_hover")

; --- TooltipPanel ---
TooltipPanel/styles/panel = SubResource("tooltip_bg")
TooltipLabel/colors/font_color = Color(0.95, 0.9, 0.8, 1)

; --- VScrollBar ---
VScrollBar/styles/scroll = SubResource("scrollbar_bg")
VScrollBar/styles/grabber = SubResource("scrollbar_grabber")
VScrollBar/styles/grabber_highlight = SubResource("scrollbar_grabber")
VScrollBar/styles/grabber_pressed = SubResource("scrollbar_grabber")

; --- HSeparator ---
HSeparator/styles/separator = SubResource("separator_style")

; --- RichTextLabel ---
RichTextLabel/colors/default_color = Color(0.95, 0.9, 0.8, 1)

; --- CheckButton ---
CheckButton/colors/font_color = Color(0.95, 0.9, 0.8, 1)
CheckButton/colors/font_hover_color = Color(1, 0.98, 0.9, 1)
