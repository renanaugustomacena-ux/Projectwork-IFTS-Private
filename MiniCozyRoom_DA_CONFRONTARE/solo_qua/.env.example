# Mini Cozy Room — Configurazione ambiente
#
# Copia questo file in user://config.cfg e compila con i tuoi valori.
# Su Windows: %APPDATA%\Godot\app_userdata\Mini Cozy Room\config.cfg
# Su macOS:   ~/Library/Application Support/Godot/app_userdata/Mini Cozy Room/config.cfg
# Su Linux:   ~/.local/share/godot/app_userdata/Mini Cozy Room/config.cfg
#
# NON committare MAI il file config.cfg nel repository.
# NON inserire MAI secrets direttamente nel codice sorgente.

# Supabase Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key (safe for client-side use, protected by RLS)
SUPABASE_ANON_KEY=your-anon-key-here
